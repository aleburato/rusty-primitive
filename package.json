{
  "name": "@aleburato/primeval",
  "version": "0.1.1",
  "private": false,
  "type": "module",
  "description": "TypeScript-first Node package for primeval image approximation.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/aleburato/primeval.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "primeval": "dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "binding.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "build:node": "napi build -p primeval-node --release --platform --js-package-name @aleburato/primeval --js binding.js --dts binding.d.ts --esm --output-dir .",
    "check:napi-targets": "node scripts/napi-targets.mjs check-package",
    "bump:version": "node scripts/napi-targets.mjs bump-version",
    "test:native:build": "npm run build && npm run build:node",
    "test:native": "node --test test/native.test.js",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run build && npm run build:node",
    "test": "node --test test/index.test.js test/contracts.test.js test/native.test.js test/cli.test.js",
    "test:tooling": "node --test test/tooling/*.test.js",
    "prepack": "npm run build"
  },
  "optionalDependencies": {
    "@aleburato/primeval-darwin-arm64": "0.1.1",
    "@aleburato/primeval-darwin-x64": "0.1.1",
    "@aleburato/primeval-linux-arm64-gnu": "0.1.1",
    "@aleburato/primeval-linux-x64-gnu": "0.1.1",
    "@aleburato/primeval-win32-x64-msvc": "0.1.1"
  },
  "napi": {
    "binaryName": "primeval-node",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc"
    ]
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.5.1",
    "@types/node": "^22.0.0",
    "typescript": "^5.5.4"
  }
}
